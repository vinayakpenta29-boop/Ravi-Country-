<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_table_card"
    android:padding="16dp"
    android:layout_marginBottom="20dp">

    <!-- Friend Name -->
    <TextView
        android:id="@+id/tvFriendName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ravi"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#990F4B"
        android:layout_marginBottom="12dp"/>

    <!-- Table Header -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_table_header"
        android:padding="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cash"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Online"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Data Container -->
    <LinearLayout
        android:id="@+id/tableRowsContainer"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- ✅ TOTAL SECTION (UPDATED) -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_table_footer"
        android:layout_marginTop="10dp">

        <!-- CENTERED LABEL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Paid"
            android:textStyle="bold"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="#888888"
            android:padding="10dp"/>

        <!-- OPTIONAL DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"/>

        <!-- TOTAL VALUES ROW -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp">

            <!-- CASH TOTAL -->
            <TextView
                android:id="@+id/tvTotalCash"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/black"/>

            <!-- ONLINE TOTAL -->
            <TextView
                android:id="@+id/tvTotalOnline"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/black"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
